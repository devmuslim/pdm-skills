{
  "_comment": "اختر إعداد Jira حسب نوع نظامك. راجع JIRA-SETUP.md للتفاصيل.",

  "mcpServers": {

    "_OPTION_A_JIRA_CLOUD": {
      "_comment": "✅ Jira Cloud — yourcompany.atlassian.net",
      "type": "sse",
      "url": "https://mcp.atlassian.com/sse",
      "env": {
        "JIRA_URL": "https://YOUR-COMPANY.atlassian.net",
        "JIRA_USERNAME": "your.email@company.com",
        "JIRA_API_TOKEN": "YOUR_API_TOKEN_HERE"
      }
    },

    "_OPTION_B_JIRA_DATA_CENTER": {
      "_comment": "✅ Jira Data Center — سيرفر داخلي",
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "JIRA_URL": "https://jira.YOUR-COMPANY.com",
        "JIRA_PERSONAL_TOKEN": "YOUR_PAT_HERE"
      }
    },

    "google-drive": {
      "_comment": "لحفظ الاتفاقيات ليقرأها agile-coach",
      "type": "sse",
      "url": "https://drive.mcp.claude.com/mcp"
    }

  }
}
